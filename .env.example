# App
APP_ENV=dev
APP_DEBUG=true
LOG_LEVEL=INFO

# PostgreSQL
POSTGRES_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/diet_ai

# MongoDB
MONGO_URL=mongodb://localhost:27017

# AI — one of: mock | claude | ollama
AI_PROVIDER=mock
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:1b

# Email — one of: mock | smtp
EMAIL_PROVIDER=mock
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM_ADDRESS=noreply@dietai.local

# Failed-email retry: background timer retries FAILED email_logs rows
EMAIL_RETRY_INTERVAL_SECONDS=180
EMAIL_RETRY_MAX_ATTEMPTS=10
EMAIL_RETRY_BATCH_LIMIT=50

JWT_SECRET_KEY=change-me
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=7

TESTING=false