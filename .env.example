# App
APP_ENV=dev
APP_DEBUG=true
LOG_LEVEL=INFO

# CORS — comma-separated origins allowed to call the API (the frontend's Vite dev server)
CORS_ORIGINS=http://localhost:5173

# CAPTCHA — one of: mock | turnstile. Guards registration and password-reset requests.
CAPTCHA_PROVIDER=mock
CAPTCHA_SECRET_KEY=

# PostgreSQL
POSTGRES_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/diet_ai

# MongoDB
MONGO_URL=mongodb://localhost:27017

# AI — one of: mock | claude | ollama
AI_PROVIDER=mock
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:1b

# Email — one of: mock | smtp
EMAIL_PROVIDER=mock
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM_ADDRESS=noreply@dietai.local

# Failed-email retry: background timer retries FAILED email_logs rows
EMAIL_RETRY_INTERVAL_SECONDS=180
EMAIL_RETRY_MAX_ATTEMPTS=10
EMAIL_RETRY_BATCH_LIMIT=50

# SFTP — one of: mock | sftp. Diet-plan CSV exports are archived here.
SFTP_PROVIDER=mock
SFTP_HOST=localhost
SFTP_PORT=2222
SFTP_USERNAME=dietai
SFTP_PASSWORD=dietai
SFTP_REMOTE_DIR=/upload

# Must be 32+ bytes (PyJWT's own recommended minimum for HS256) or the
# app logs an InsecureKeyLengthWarning; generate a real one with
# `python -c "import secrets; print(secrets.token_urlsafe(32))"`.
JWT_SECRET_KEY=EwJ1mhW-IB1iBvdpGsGcqv8tu-w3B44NbPCGH7BLdQE-change-me
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=7

# Kafka — one of: mock | kafka. TransactionPaid events (notifications + messaging).
KAFKA_PROVIDER=mock
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Rate limiting — one of: mock | redis. Guards login/register/password-reset-request.
RATE_LIMIT_PROVIDER=mock
REDIS_URL=redis://localhost:6379/0
RATE_LIMIT_MAX_ATTEMPTS=5
RATE_LIMIT_WINDOW_SECONDS=60

TESTING=false