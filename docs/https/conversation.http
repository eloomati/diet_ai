### Conversation MVP smoke tests
### Base URL (zmień jeśli backend działa na innym porcie/hoście)
@baseUrl = http://localhost:8000
@authPrefix = /api/v1/auth
@conversationsPrefix = /api/v1/conversations

### Dane testowego użytkownika (właściciela konwersacji)
@email = convo.demo@example.com
@password = StrongPass123

### =========================
### 1) Register (właściciel)
### =========================
POST {{baseUrl}}{{authPrefix}}/register
Content-Type: application/json

{
  "email": "{{email}}",
  "password": "{{password}}"
}

### =========================
### 2) Login (zapis tokena do zmiennej)
### =========================
# @name login
POST {{baseUrl}}{{authPrefix}}/login
Content-Type: application/json

{
  "email": "{{email}}",
  "password": "{{password}}"
}

> {%
  client.global.set("access_token", response.body.access_token);
%}

### =========================
### 3) Create conversation (zapis conversation_id)
### categories: lista, min. 1 wartość — tu dwie naraz, żeby pokazać multi-select
### =========================
# @name createConversation
POST {{baseUrl}}{{conversationsPrefix}}
Authorization: Bearer {{access_token}}
Content-Type: application/json

{
  "title": "High protein breakfasts",
  "categories": ["BREAKFAST", "DIET"]
}

> {%
  client.global.set("conversation_id", response.body.conversation_id);
%}

### =========================
### 4) List conversations (właściciela)
### =========================
GET {{baseUrl}}{{conversationsPrefix}}
Authorization: Bearer {{access_token}}

### =========================
### 5) Send message (realna odpowiedź AI — zależnie od AI_PROVIDER)
### =========================
POST {{baseUrl}}{{conversationsPrefix}}/{{conversation_id}}/messages
Authorization: Bearer {{access_token}}
Content-Type: application/json

{
  "content": "I run 5 times a week. Suggest a high protein breakfast."
}

### =========================
### 6) Get conversation history (powinna zawierać 2 wiadomości: USER + ASSISTANT)
### =========================
GET {{baseUrl}}{{conversationsPrefix}}/{{conversation_id}}
Authorization: Bearer {{access_token}}

### =========================
### 7) Negatywny test: brak tokena
### Oczekiwane: 401 + code INVALID_ACCESS_TOKEN
### =========================
GET {{baseUrl}}{{conversationsPrefix}}

### =========================
### 8) Negatywny test: nieznana kategoria
### Oczekiwane: 422 + code VALIDATION_ERROR
### =========================
POST {{baseUrl}}{{conversationsPrefix}}
Authorization: Bearer {{access_token}}
Content-Type: application/json

{
  "title": "Bad category",
  "categories": ["NOT_A_REAL_CATEGORY"]
}

### =========================
### 8b) Negatywny test: pusta lista kategorii
### Oczekiwane: 422 + code VALIDATION_ERROR
### =========================
POST {{baseUrl}}{{conversationsPrefix}}
Authorization: Bearer {{access_token}}
Content-Type: application/json

{
  "title": "No categories",
  "categories": []
}

### =========================
### 9) Negatywny test: nieistniejąca konwersacja
### Oczekiwane: 404 + code NOT_FOUND
### =========================
GET {{baseUrl}}{{conversationsPrefix}}/00000000-0000-0000-0000-000000000000
Authorization: Bearer {{access_token}}

### =========================
### 10) Drugi użytkownik — register + login (do testu izolacji danych)
### =========================
# @name loginOther
POST {{baseUrl}}{{authPrefix}}/register
Content-Type: application/json

{
  "email": "convo.other@example.com",
  "password": "StrongPass123"
}

###
POST {{baseUrl}}{{authPrefix}}/login
Content-Type: application/json

{
  "email": "convo.other@example.com",
  "password": "StrongPass123"
}

> {%
  client.global.set("other_access_token", response.body.access_token);
%}

### =========================
### 11) Negatywny test: drugi user nie widzi cudzej konwersacji
### Oczekiwane: 404 + code NOT_FOUND (nie 403 — nie zdradzamy, że konwersacja istnieje)
### =========================
GET {{baseUrl}}{{conversationsPrefix}}/{{conversation_id}}
Authorization: Bearer {{other_access_token}}

### =========================
### 12) Negatywny test: drugi user nie może wysłać wiadomości do cudzej konwersacji
### Oczekiwane: 404 + code NOT_FOUND
### =========================
POST {{baseUrl}}{{conversationsPrefix}}/{{conversation_id}}/messages
Authorization: Bearer {{other_access_token}}
Content-Type: application/json

{
  "content": "Sneaky message"
}

### =========================
### 13) Archive conversation (status -> ARCHIVED, wciąż czytelna)
### =========================
POST {{baseUrl}}{{conversationsPrefix}}/{{conversation_id}}/archive
Authorization: Bearer {{access_token}}

### =========================
### 14) Negatywny test: wiadomość do zarchiwizowanej konwersacji
### Oczekiwane: 409 + code CONFLICT
### =========================
POST {{baseUrl}}{{conversationsPrefix}}/{{conversation_id}}/messages
Authorization: Bearer {{access_token}}
Content-Type: application/json

{
  "content": "This should be rejected — conversation is archived."
}

### =========================
### 15) Get conversation — archiwizacja nie blokuje odczytu, tylko zapis
### =========================
GET {{baseUrl}}{{conversationsPrefix}}/{{conversation_id}}
Authorization: Bearer {{access_token}}

### =========================
### 16) Delete conversation — trwałe, bez cofnięcia
### Oczekiwane: 204 No Content
### =========================
DELETE {{baseUrl}}{{conversationsPrefix}}/{{conversation_id}}
Authorization: Bearer {{access_token}}

### =========================
### 17) Negatywny test: get po delete
### Oczekiwane: 404 + code NOT_FOUND
### =========================
GET {{baseUrl}}{{conversationsPrefix}}/{{conversation_id}}
Authorization: Bearer {{access_token}}
