VITE_API_BASE_URL=http://localhost:8000/api/v1

# Where the separate admin panel app (frontend-admin) is reachable — the
# "Panel Administratorski" link shown to ADMIN/SUPER_ADMIN users points here.
VITE_ADMIN_PANEL_URL=http://localhost:5174

# Cloudflare Turnstile site key — leave empty for local dev (falls back to a
# placeholder token, which the backend's default CAPTCHA_PROVIDER=mock accepts)
VITE_TURNSTILE_SITE_KEY=
